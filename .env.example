# Required for:
# - scripts/fetch-contributions.mjs
# - api/contributions.js
# - api/share-card.js
#
# Use a GitHub token that can call the GitHub GraphQL API.
GITHUB_TOKEN=your_github_token_here

# Optional frontend override for the dynamic share image/API origin.
# Leave empty when frontend and API are deployed on the same Vercel project.
# Example:
# VITE_SHARE_IMAGE_ORIGIN=https://horse-ucg.vercel.app
VITE_SHARE_IMAGE_ORIGIN=

# Optional Vite base path override.
# Keep "/" for Vercel root deployment.
# Example:
# VITE_BASE_PATH=/horse-ucg/
VITE_BASE_PATH=/
